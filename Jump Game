class Solution {
    public boolean canJump(int[] nums) {

        int maxReach = 0;
        int n = nums.length;

        for (int i = 0; i < n; i++) {
            if (i > maxReach) return false; // can't reach this position
            maxReach = Math.max(maxReach, i + nums[i]);
        }

        return true;
    }
}
